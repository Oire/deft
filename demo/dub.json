{
	"name": "deft-demo",
	"description": "Demo application for the Deft UI framework",
	"authors": [
		"André Polykanine"
	],
	"license": "BSL-1.0",
	"targetType": "executable",
	"dependencies": {
		"deft": {
			"path": "../"
		},
		"mofile": "~>0.2.1"
	},
	"preGenerateCommands-windows": [
		"powershell -NoProfile -ExecutionPolicy Bypass -File \"$PACKAGE_DIR/make-res.ps1\""
	],
	"sourceFiles-windows": [
		"app.res"
	],
	"lflags-windows-dmd": [
		"/SUBSYSTEM:WINDOWS",
		"/ENTRY:mainCRTStartup"
	],
	"lflags-windows-ldc": [
		"/SUBSYSTEM:WINDOWS",
		"/ENTRY:wmainCRTStartup"
	]
}
