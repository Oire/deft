# Compiled Object files
*.o
*.obj

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.a
*.lib

# Executables
*.exe

# Debug symbols / linker intermediates (MSVC linker keeps these out of the .exe)
*.pdb
*.ilk
*.exp

# rc.exe leftover temporary files (left behind only when a resource compile fails)
RC[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]*

# DUB
.dub
docs.json
__dummy.html
dub.selections.json

# Generated API documentation (DDoc). `dub build -b ddoc` writes to api/.
# docs/*.html guards against the built-in `-b docs`, which would write into
# docs/ — it can only match generated HTML, never the .md plans in docs/plans/.
/api/
docs/*.html

# Code coverage
*.lst
